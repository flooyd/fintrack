# Drizzle — PostgreSQL connection string
DATABASE_URL="postgres://user:password@localhost:5432/fintrack"

# Base URL of the app (used by Better Auth for callbacks)
ORIGIN="http://localhost:5173"

# Better Auth
# For production use 32 characters generated with high entropy
# https://www.better-auth.com/docs/installation
BETTER_AUTH_SECRET=""

# Social logins (optional). Buttons render only when the matching pair is set.
# Google OAuth — https://www.better-auth.com/docs/authentication/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
# GitHub OAuth — https://www.better-auth.com/docs/authentication/github
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
